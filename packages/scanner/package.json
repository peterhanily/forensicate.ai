{
  "name": "@forensicate/scanner",
  "version": "1.0.0",
  "description": "AI prompt injection detection engine with 149 rules across keyword, regex, heuristic, NLP, and file-based detection",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./rules": {
      "types": "./dist/rules.d.ts",
      "import": "./dist/rules.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "bin": {
    "forensicate": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "prompt-injection",
    "ai-security",
    "llm-security",
    "jailbreak-detection",
    "owasp",
    "scanner",
    "firewall",
    "ai",
    "llm",
    "nlp",
    "chatgpt",
    "detection"
  ],
  "author": "Forensicate.ai",
  "license": "Apache-2.0",
  "homepage": "https://forensicate.ai",
  "bugs": {
    "url": "https://github.com/peterhanily/forensicate.ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/peterhanily/forensicate.ai",
    "directory": "packages/scanner"
  },
  "dependencies": {
    "compromise": "^14.15.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
